      path: 0
      path: 2
      path: 0
      path: 1
      span: 57
      span: 20
      span: 27
    }
    location: {
      path: 4
      path: 0
      path: 2
      path: 0
      path: 3
      span: 57
      span: 30
      span: 31
    }
    location: {
      path: 4
      path: 1
      span: 61
      span: 0
      span: 70
      span: 1
      leading_comments: " Socket describes a single forwarded UNIX socket.\n"
    }
    location: {
      path: 4
      path: 1
      path: 1
      span: 61
      span: 8
      span: 14
    }
    location: {
      path: 4
      path: 1
      path: 2
      path: 0
      path: 5
      span: 64
      span: 4
      span: 10
    }
    location: {
      path: 4
      path: 1
      path: 2
      path: 0
      span: 64
      span: 4
      span: 26
      leading_comments: " Opaque identifier for this forward. Each side uses it to resolve the local\n socket path from its own configuration.\n"
    }
    location: {
      path: 4
      path: 1
      path: 2
      path: 0
      path: 1
      span: 64
      span: 11
      span: 21
    }
    location: {
      path: 4
      path: 1
      path: 2
      path: 0
      path: 3
      span: 64
      span: 24
      span: 25
    }
    location: {
      path: 4
      path: 1
      path: 2
      path: 1
      path: 5
      span: 69
      span: 4
      span: 10
    }
    location: {
      path: 4
      path: 1
      path: 2
      path: 1
      span: 69
      span: 4
      span: 27
      leading_comments: " Path of the UNIX listener socket in the VM's root filesystem (e.g.\n /run/socketfwd/{forward_id}.sock). vminitd creates the socket here;\n the shim has already rewritten the uds mount to a bind mount from\n this path to the user-specified destination inside the container.\n"
    }
    location: {
      path: 4
      path: 1
      path: 2
      path: 1
      path: 1
      span: 69
      span: 11
      span: 22
    }
    location: {
      path: 4
      path: 1
      path: 2
      path: 1
      path: 3
      span: 69
      span: 25
      span: 26
    }
    location: {
      path: 4
      path: 2
      span: 74
      span: 0
      span: 82
      span: 1
      leading_comments: " ConnectRequest is sent by the VM on the Accept stream to notify the host of\n a new container-initiated connection.\n"
    }
    location: {
      path: 4
      path: 2
      path: 1
      span: 74
      span: 8
      span: 22
    }
    location: {
      path: 4
      path: 2
      path: 2
      path: 0
      path: 5
      span: 77
      span: 4
      span: 10
    }
    location: {
      path: 4
      path: 2
      path: 2
      path: 0
      span: 77
      span: 4
      span: 25
      leading_comments: " ID of the vsock stream. The host must open a stream with this ID after\n a successful ConnectResult so that the relay can start.\n"
    }
    location: {
      path: 4
      path: 2
      path: 2
      path: 0
      path: 1
      span: 77
      span: 11
      span: 20
    }
    location: {
      path: 4
      path: 2
      path: 2
      path: 0
      path: 3
      span: 77
      span: 23
      span: 24
    }
    location: {
      path: 4
      path: 2
      path: 2
      path: 1
      path: 5
      span: 81
      span: 4
      span: 10
    }
    location: {
      path: 4
      path: 2
      path: 2
      path: 1
      span: 81
      span: 4
      span: 26
      leading_comments: " Identifier of the socket forward entry. The host uses this to resolve the\n target host socket path from its own configuration rather than trusting a\n path supplied by the VM.\n"
    }
    location: {
      path: 4
      path: 2
      path: 2
      path: 1
      path: 1
      span: 81
      span: 11
      span: 21
    }
    location: {
      path: 4
      path: 2
      path: 2
      path: 1
      path: 3
      span: 81
      span: 24
      span: 25
    }
    location: {
      path: 4
      path: 3
      span: 88
      span: 0
      span: 94
      span: 1
      leading_comments: " ConnectResult is sent by the host on the Accept stream in response to each\n ConnectRequest. It reports whether the host successfully dialed the target\n socket. On failure the VM closes the pending container connection\n immediately.\n"
    }
    location: {
      path: 4
      path: 3
      path: 1
      span: 88
      span: 8
      span: 21
    }
    location: {
      path: 4
      path: 3
      path: 2
      path: 0
      path: 5
      span: 90
      span: 4
      span: 10
    }
    location: {
      path: 4
      path: 3
      path: 2
      path: 0
      span: 90
      span: 4
      span: 25
      leading_comments: " ID of the vsock stream from the corresponding ConnectRequest.\n"
    }
    location: {
      path: 4
      path: 3
      path: 2
      path: 0
      path: 1
      span: 90
      span: 11
      span: 20
    }
    location: {
      path: 4
      path: 3
      path: 2
      path: 0
      path: 3
      span: 90
      span: 23
      span: 24
    }
    location: {
      path: 4
      path: 3
      path: 2
      path: 1
      path: 5
      span: 93
      span: 4
      span: 10
    }
    location: {
      path: 4
      path: 3
      path: 2
      path: 1
      span: 93
      span: 4
      span: 21
      leading_comments: " Non-empty if the host failed to dial the target socket. The VM closes\n the pending connection when error is set.\n"
    }
    location: {
      path: 4
      path: 3
      path: 2
      path: 1
      path: 1
      span: 93
      span: 11
      span: 16
    }
    location: {
      path: 4
      path: 3
      path: 2
      path: 1
      path: 3
      span: 93
      span: 19
      span: 20
    }
  }
  syntax: "proto3"
  buf_extension: {
    is_import: false
    is_syntax_unspecified: false
  }
}
